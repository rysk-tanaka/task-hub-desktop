{
	"name": "task-hub-desktop",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"preview": "vite preview",
		"tauri": "tauri",
		"cargo:check": "cargo check --manifest-path src-tauri/Cargo.toml",
		"cargo:test": "cargo test --manifest-path src-tauri/Cargo.toml",
		"cargo:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
		"cargo:coverage": "cargo tarpaulin --manifest-path src-tauri/Cargo.toml --skip-clean --out stdout"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/plugin-dialog": "^2.6.0",
		"@tauri-apps/plugin-shell": "^2.3.5",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@tauri-apps/cli": "^2.10.1",
		"@types/node": "^24.12.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.4",
		"typescript": "~5.9.3",
		"vite": "^7.3.1"
	},
	"packageManager": "pnpm@10.32.1"
}
