{
  "$schema": "https://raw.githubusercontent.com/nicedouble/tauri-apps-tauri-2/dev/crates/tauri-config-schema/schema.json",
  "productName": "Task Hub",
  "version": "0.1.0",
  "identifier": "com.task-hub-desktop.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Task Hub",
        "width": 1024,
        "height": 768
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
